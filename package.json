{
  "name": "emplai-biometric-agent",
  "version": "1.0.0",
  "description": "",
  "bin": "server.js",
  "pkg": {
    "targets": [
      "node18-win-x64"
    ],
    "outputPath": "dist"
  },
  "scripts": {
    "dev": "nodemon server.js",
    "service-install": "node scripts/installService.js",
    "service-uninstall": "node scripts/uninstallService.js"
  },
  "build": {
    "appId": "com.emplai.biometric",
    "productName": "Emplai Biometric Agent",
    "directories": {
      "output": "release"
    },
    "files": [
      "agent-core/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": [
        "deb",
        "AppImage"
      ],
      "category": "Utility"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.16.0",
    "body-parser": "^2.2.2",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "fs-extra": "^11.3.5",
    "mssql": "^12.5.2",
    "mysql2": "^3.22.3",
    "node-cron": "^4.2.1",
    "node-windows": "^1.0.0-beta.8",
    "open": "^11.0.0",
    "readline-sync": "^1.4.10",
    "uuid": "^13.0.2",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "pkg": "^5.8.1"
  }
}
